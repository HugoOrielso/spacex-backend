{
    "family": "spacex-backend-task",
    "executionRoleArn": "arn:aws:iam::148761674962:role/ecsTaskExecutionRole-spacex-infra",
    "taskRoleArn": "arn:aws:iam::148761674962:role/ecsTaskExecutionRole-spacex-infra",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "containerDefinitions": [
        {
            "name": "spacex-backend",
            "image": "148761674962.dkr.ecr.us-east-2.amazonaws.com/spacex-backend:latest",
            "portMappings": [
                {
                    "containerPort": 4000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "secrets": [
                {
                    "name": "TABLE_NAME",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:148761674962:secret:spacex-backend-secrets-kSlcVf:TABLE_NAME::"
                },
                {
                    "name": "PORT",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:148761674962:secret:spacex-backend-secrets-kSlcVf:PORT::"
                }
            ],
            "environment": [
                {
                    "name": "AWS_DEFAULT_REGION",
                    "value": "us-east-2"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/spacex-backend",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs",
                    "awslogs-create-group": "true"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:4000/health || exit 1"
                ],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            }
        }
    ]
}